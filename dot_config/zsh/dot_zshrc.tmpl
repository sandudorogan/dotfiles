export ZSH="$HOME/.config/oh-my-zsh"

# Cache dir for init scripts
_zsh_cache="$HOME/.cache/zsh/eval-cache"
[[ -d "$_zsh_cache" ]] || mkdir -p "$_zsh_cache"

# Source a cached init script, regenerating if the binary has changed
_cached_source() {
  local name="$1" bin="$2"; shift 2
  local cache="$_zsh_cache/$name.zsh"
  if [[ ! -f "$cache" || "$bin" -nt "$cache" ]]; then
    "$@" > "$cache" 2>/dev/null
  fi
  source "$cache"
}

# Direnv (cached)
{ local _bin="$(command -v direnv)"; [[ -n "$_bin" ]] && _cached_source direnv "$_bin" direnv hook zsh; }

# Shell options
autoload -U colors && colors
setopt autocd
stty stop undef
setopt interactive_comments

# History configuration
HISTSIZE=10000000
SAVEHIST=10000000
HISTFILE=~/.cache/zsh/history

# Import colorscheme from 'wal' asynchronously
[ -f ~/.cache/wal/sequences ] && (cat ~/.cache/wal/sequences &)

# Oh My Zsh Theme
ZSH_THEME="robbyrussell"

# Oh My Zsh Settings
HYPHEN_INSENSITIVE="true"
COMPLETION_WAITING_DOTS="true"
HIST_STAMPS="dd/mm/yyyy"

# Oh My Zsh auto-update configuration (modern zstyle format)
zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 13

# Skip compaudit security check (saves ~25ms per startup)
ZSH_DISABLE_COMPFIX=true

# Vim mode settings
VI_MODE_SET_CURSOR=true
VI_MODE_RESET_PROMPT_ON_MODE_CHANGE=true

# Oh My Zsh plugins
plugins=(
    git
    tmux
    colorize
    colored-man-pages
    copybuffer
    common-aliases
    emoji
    emoji-clock
    web-search
    fancy-ctrl-z
    urltools
    zsh-navigation-tools
    zsh-interactive-cd
    universalarchive
    vi-mode
    lein
{{ if eq .chezmoi.os "darwin" -}}
    macos
{{ end -}}
    zsh-autosuggestions
    zsh-syntax-highlighting
 )

ZSH_COMPDUMP="$HOME/.config/zsh/.zcompdump"

source $ZSH/oh-my-zsh.sh

# Recompile zcompdump in background if stale
{
  local dump="$ZSH_COMPDUMP"
  if [[ -s "$dump" && (! -s "$dump.zwc" || "$dump" -nt "$dump.zwc") ]]; then
    zcompile "$dump"
  fi
} &!

# Fzf integration (cached, after compinit for completion)
{ local _bin="$(command -v fzf)"; [[ -n "$_bin" ]] && _cached_source fzf "$_bin" fzf --zsh; }

# Initialize Atuin (cached, after Oh My Zsh plugins)
{ local _bin="$(command -v atuin)"; [[ -n "$_bin" ]] && _cached_source atuin "$_bin" atuin init zsh; }

# Zoxide (cached)
{ local _bin="$(command -v zoxide)"; [[ -n "$_bin" ]] && _cached_source zoxide "$_bin" zoxide init zsh; }

# Use vim keys in tab complete menu:
bindkey -M menuselect 'h' vi-backward-char
bindkey -M menuselect 'k' vi-up-line-or-history
bindkey -M menuselect 'l' vi-forward-char
bindkey -M menuselect 'j' vi-down-line-or-history
bindkey -v '^?' backward-delete-char

bindkey '^ ' autosuggest-accept

# export MANPATH="/usr/local/man:$MANPATH"

# Compilation flags
# export ARCHFLAGS="-arch x86_64"

# Load the default NVM Node so child processes like Neovim inherit it.
export NVM_DIR="$([ -z "${XDG_CONFIG_HOME-}" ] && printf %s "${HOME}/.nvm" || printf %s "${XDG_CONFIG_HOME}/nvm")"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  \. "$NVM_DIR/nvm.sh" --no-use
  nvm use --silent default >/dev/null 2>&1
  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
fi

# Load aliases and shortcuts if existent
[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/shortcutrc" ] && source "${XDG_CONFIG_HOME:-$HOME/.config}/shell/shortcutrc"
[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/aliasrc" ] && source "${XDG_CONFIG_HOME:-$HOME/.config}/shell/aliasrc"
[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/zshnameddirrc" ] && source "${XDG_CONFIG_HOME:-$HOME/.config}/shell/zshnameddirrc"

{{ if eq .chezmoi.os "darwin" -}}
# Docker-sync workaround for macOS
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
{{ end -}}

# Lazy-load thefuck — only initializes when 'fuck' is first called
if command -v thefuck &>/dev/null; then
  fuck() {
    unset -f fuck
    eval $(thefuck --alias)
    fuck "$@"
  }
fi

{{ if eq .chezmoi.os "darwin" -}}
# PATH additions
export PATH="$HOME/.cache/.bun/bin:$HOMEBREW_PREFIX/opt/openjdk/bin:$PATH"
{{ end -}}

# Completions
[ -s "{{ .chezmoi.homeDir }}/.bun/_bun" ] && source "{{ .chezmoi.homeDir }}/.bun/_bun"

# Load custom environment if it exists
[ -f "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"
